+static void handle_handover_control(rc_ctrl_req_data_t const* ctrl)
+{
+  const seq_ran_param_t* ran_param = ctrl->msg.frmt_1.ran_param;
+  printf("[E2 AGENT][DEBUG] Livello 1: ran_param_id=%u, type=%d\n", ran_param[0].ran_param_id, ran_param[0].ran_param_val.type);
+  // Livello 1: Target Primary Cell ID (id=1, STRUCTURE)
+  if (ran_param[0].ran_param_id == 1 &&
+      ran_param[0].ran_param_val.type == STRUCTURE_RAN_PARAMETER_VAL_TYPE) {
+    ran_param_struct_t* target_cell_struct = ran_param[0].ran_param_val.strct;
+    const seq_ran_param_t* target_cell = target_cell_struct->ran_param_struct;
+    printf("[E2 AGENT][DEBUG] Livello 2: ran_param_id=%u, type=%d\n", target_cell[0].ran_param_id, target_cell[0].ran_param_val.type);
+    // Livello 2: Target Cell (id=2, STRUCTURE)
+    if (target_cell[0].ran_param_id == 2 &&
+        target_cell[0].ran_param_val.type == STRUCTURE_RAN_PARAMETER_VAL_TYPE) {
+      ran_param_struct_t* nr_cell_struct = target_cell[0].ran_param_val.strct;
+      const seq_ran_param_t* nr_cell = nr_cell_struct->ran_param_struct;
+      printf("[E2 AGENT][DEBUG] Livello 3: ran_param_id=%u, type=%d\n", nr_cell[0].ran_param_id, nr_cell[0].ran_param_val.type);
+      // Livello 3: NR Cell (id=3, STRUCTURE)
+      if (nr_cell[0].ran_param_id == 3 &&
+          nr_cell[0].ran_param_val.type == STRUCTURE_RAN_PARAMETER_VAL_TYPE) {
+        ran_param_struct_t* nr_cgi_struct = nr_cell[0].ran_param_val.strct;
+        const seq_ran_param_t* nr_cgi = nr_cgi_struct->ran_param_struct;
+        printf("[E2 AGENT][DEBUG] Livello 4: ran_param_id=%u, type=%d\n", nr_cgi[0].ran_param_id, nr_cgi[0].ran_param_val.type);
+        // Livello 4: NR CGI (id=4, valore foglia)
+        if (nr_cgi[0].ran_param_id == 4 &&
+            nr_cgi[0].ran_param_val.type == ELEMENT_KEY_FLAG_TRUE_RAN_PARAMETER_VAL_TYPE) {
+          ran_parameter_value_t* val = nr_cgi[0].ran_param_val.flag_true;
+          if (val->type == OCTET_STRING_RAN_PARAMETER_VALUE) {
+            const uint8_t* buf = val->octet_str_ran.buf;
+            size_t len = val->octet_str_ran.len;
+            printf("[E2 AGENT] NR CGI octet string: ");
+            for (size_t i = 0; i < len; ++i) printf("%02X ", buf[i]);
+            printf("\n");
+            // Parsing corretto dell'octet string dalla xApp
+            // Formato: [MCC][MNC][MNC][gNB_ID_byte1][gNB_ID_byte2][gNB_ID_byte3][gNB_ID_byte4][Cell_ID_byte1]
+            uint8_t mcc = buf[0];
+            uint8_t mnc_high = buf[1];
+            uint8_t mnc_low = buf[2];
+            uint32_t gnb_id = (buf[3] << 24) | (buf[4] << 16) | (buf[5] << 8) | buf[6];
+            // Parsing corretto del Cell ID (4 byte), Physical Cell ID (2 byte) e TAC (2 byte)
+            uint64_t cell_id = 0;
+            uint16_t physical_cell_id = 0;
+            uint16_t tac = 0;
+            
+            if (len >= 15) {
+                // Formato completo: Cell ID nei byte 7-10 (4 byte), PCI nei byte 11-12 (2 byte), TAC nei byte 13-14 (2 byte)
+                cell_id = ((uint64_t)buf[7] << 24) | ((uint64_t)buf[8] << 16) | ((uint64_t)buf[9] << 8) | buf[10];
+                physical_cell_id = ((uint16_t)buf[11] << 8) | buf[12];
+                tac = ((uint16_t)buf[13] << 8) | buf[14];
+            } else if (len >= 13) {
+                // Formato intermedio: Cell ID nei byte 7-10 (4 byte), PCI nei byte 11-12 (2 byte), TAC = 0
+                cell_id = ((uint64_t)buf[7] << 24) | ((uint64_t)buf[8] << 16) | ((uint64_t)buf[9] << 8) | buf[10];
+                physical_cell_id = ((uint16_t)buf[11] << 8) | buf[12];
+                tac = 0;
+            } else if (len >= 11) {
+                // Formato intermedio: Cell ID nei byte 7-10 (4 byte), PCI = 0, TAC = 0
+                cell_id = ((uint64_t)buf[7] << 24) | ((uint64_t)buf[8] << 16) | ((uint64_t)buf[9] << 8) | buf[10];
+                physical_cell_id = 0;
+                tac = 0;
+            } else {
+                // Fallback per compatibilità con formato vecchio (1 byte)
+                cell_id = (uint64_t)buf[7];
+                physical_cell_id = 0;
+                tac = 0;
+            }
+            
+            printf("[E2 AGENT] Parsing corretto dell'octet string:\n");
+            printf("[E2 AGENT] - MCC: %u\n", mcc);
+            printf("[E2 AGENT] - MNC: %u%u\n", mnc_high, mnc_low);
+            printf("[E2 AGENT] - gNB ID: 0x%x\n", gnb_id);
+            printf("[E2 AGENT] - Cell ID: %lu\n", cell_id);
+            printf("[E2 AGENT] - Physical Cell ID: %u\n", physical_cell_id);
+            printf("[E2 AGENT] - TAC: 0x%04x (%u)\n", tac, tac);
+            // --- Recupero UE e trigger HO come prima ---
+            ue_id_e2sm_t ue_id = ctrl->hdr.frmt_1.ue_id;
+            //log che stampa l'id del UE
+            printf("[E2 AGENT] UE ID: %lu\n", ue_id.gnb.amf_ue_ngap_id);
+            uint64_t internal_ue_id = 0;
+            switch (ue_id.type) {
+              case GNB_UE_ID_E2SM:
+                internal_ue_id = ue_id.gnb.amf_ue_ngap_id;
+                break;
+              default:
+                printf("[E2 AGENT] Tipo UE ID non gestito: %d\n", ue_id.type);
+                return;
+            }
+            printf("[E2 AGENT] Internal UE ID: %lu\n", internal_ue_id);
+            gNB_RRC_INST *rrc = RC.nrrrc[0];
+            if (!rrc) {
+              printf("[E2 AGENT] RRC context non trovato!\n");
+              return;
+            }
+            print_all_active_rrc_ue_ids(rrc);
+            rrc_gNB_ue_context_t *ue_context_p = rrc_gNB_get_ue_context(rrc, internal_ue_id);
+            if (!ue_context_p) {
+              // Provo anche con amf_ue_ngap_id
+              ue_context_p = find_ue_context_by_amf_ue_ngap_id(rrc, internal_ue_id);
+              if (ue_context_p) {
+                printf("[E2 AGENT] UE context trovato tramite amf_ue_ngap_id=%lu (rrc_ue_id=%u)\n", internal_ue_id, ue_context_p->ue_context.rrc_ue_id);
+              }
+            }
+            if (ue_context_p) {
+#if defined(NGRAN_GNB_DU) && defined(NGRAN_GNB_CUCP)
+              gNB_RRC_UE_t *ue = &ue_context_p->ue_context;
+
+              // Recupera il PCI della serving cell (source) dell'UE
+              struct nr_rrc_du_container_t *du = get_du_for_ue(rrc, ue->rrc_ue_id);
+              if (!du) {
+                printf("[E2 AGENT] DU non trovato per UE %u, impossibile triggerare HO\n", ue->rrc_ue_id);
+                return;
+              }
+              int serving_pci = du->setup_req->cell[0].info.nr_pci;
+              printf("[E2 AGENT] Source/Serving Cell PCI: %d\n", serving_pci);
+
+              // Configurazione neighbour basata sui valori dalla xApp
+              nr_neighbour_gnb_configuration_t neighbour_config = {
+                .isIntraFrequencyNeighbour = true,
+                .gNB_ID = gnb_id, // ✅ Usa gNB ID dalla xApp
+                .nrcell_id = cell_id, // ✅ Usa Cell ID dalla xApp
+                .physicalCellId = physical_cell_id, // ✅ Usa Physical Cell ID dalla xApp (target)
+                .plmn.mcc = mcc, // ✅ Usa MCC dalla xApp
+                .plmn.mnc = (mnc_high * 10) + mnc_low, // ✅ Usa MNC dalla xApp
+                .plmn.mnc_digit_length = 2,
+                .subcarrierSpacing = 30, // Default value
+                .tac = tac // ✅ Usa TAC dalla xApp
+              };
+
+              printf("[E2 AGENT] Configurazione handover dalla xApp:\n");
+              printf("[E2 AGENT] - Source PCI (serving cell): %d\n", serving_pci);
+              printf("[E2 AGENT] - Target gNB ID: 0x%x\n", neighbour_config.gNB_ID);
+              printf("[E2 AGENT] - Target Cell ID: %lu\n", neighbour_config.nrcell_id);
+              printf("[E2 AGENT] - Target Physical Cell ID: %u\n", neighbour_config.physicalCellId);
+              printf("[E2 AGENT] - PLMN: MCC=%u, MNC=%u\n", neighbour_config.plmn.mcc, neighbour_config.plmn.mnc);
+              printf("[E2 AGENT] - TAC: 0x%04x (%u)\n", neighbour_config.tac, neighbour_config.tac);
+
+              // CORREZIONE: passa serving_pci (source) invece di physicalCellId (target)
+              nr_rrc_trigger_n2_ho(rrc, ue, serving_pci, &neighbour_config);
+              printf("[E2 AGENT] Triggerato handover inter-CU verso gNB 0x%x, cella %lu\n", gnb_id, cell_id);
+#else
+              printf("[E2 AGENT] Handover control non supportato su questo nodo (CU-UP)\n");
+#endif
+            } else {
+              printf("[E2 AGENT] UE context non trovato, impossibile triggerare HO\n");
+              printf("[E2 AGENT] Possibili cause:\n");
+              printf("[E2 AGENT] - UE già completato handover verso target gNB\n");
+              printf("[E2 AGENT] - UE disconnesso\n");
+              printf("[E2 AGENT] - UE ID non valido\n");
+              printf("[E2 AGENT] - Problema di sincronizzazione tra xApp e gNB\n");
+            }
+            return;
+          }
+        }
+      }
+    }
+  }
+  printf("[E2 AGENT] Struttura IE handover non riconosciuta o incompleta\n");
+}
+
+sm_ag_if_ans_t write_ctrl_rc_sm(void const* data)
+{
+  assert(data != NULL);
+  //  assert(data->type == RAN_CONTROL_CTRL_V1_03 );
+
+  rc_ctrl_req_data_t const* ctrl = (rc_ctrl_req_data_t const*)data;
+
+  assert(ctrl->hdr.format == FORMAT_1_E2SM_RC_CTRL_HDR && "Indication Header Format received not valid");
+  assert(ctrl->msg.format == FORMAT_1_E2SM_RC_CTRL_MSG && "Indication Message Format received not valid");
+
+  const uint32_t ric_style_type = ctrl->hdr.frmt_1.ric_style_type;
+  const uint32_t ctrl_act_id = ctrl->hdr.frmt_1.ctrl_act_id;
+
+  // Handle Radio Bearer Control (Style Type 1)
+  if (ric_style_type == 1) {
+    if (ctrl_act_id == 2) {
+      printf("QoS flow mapping configuration\n");
+      handle_qos_flow_mapping_config(ctrl);
+    } else {
+      AssertError(false,
+                  return (sm_ag_if_ans_t){0},
+                  "[E2 AGENT] Control Action ID %d not supported for Radio Bearer Control (Style Type 1)\n",
+                  ctrl_act_id);
+    }
+  }
+  // Handle Connected Mode Mobility Control (Style Type 3)
+  else if (ric_style_type == 3) {
+    if (ctrl_act_id == 1) {
+      printf("Handover Control\n");
+      handle_handover_control(ctrl);
+    } else {
+      AssertError(false,
+                  return (sm_ag_if_ans_t){0},
+                  "[E2 AGENT] Control Action ID %d not supported for Connected Mode Mobility Control (Style Type 3)\n",
+                  ctrl_act_id);
+    }
+  }
+  // Handle legacy case for backward compatibility
+  else if (ctrl_act_id == 2) {
+    printf("QoS flow mapping configuration\n");
+    handle_qos_flow_mapping_config(ctrl);
+  } else {
+    AssertError(false,
+                return (sm_ag_if_ans_t){0},
+                "[E2 AGENT] Control Style Type %d and Control Action ID %d not supported\n",
+                ric_style_type,
+                ctrl_act_id);
+  }
 
   sm_ag_if_ans_t ans = {.type = CTRL_OUTCOME_SM_AG_IF_ANS_V0};
   ans.ctrl_out.type = RAN_CTRL_V1_3_AGENT_IF_CTRL_ANS_V0;
