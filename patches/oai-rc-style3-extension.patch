+// Funzione di debug per stampare tutti gli rrc_ue_id attivi nella gNB
+static void print_all_active_rrc_ue_ids(gNB_RRC_INST *rrc) {
+  printf("[E2 AGENT][DEBUG] Lista rrc_ue_id attivi nella gNB: ");
+  rrc_gNB_ue_context_t *ue_context_p = NULL;
+  int count = 0;
+  RB_FOREACH(ue_context_p, rrc_nr_ue_tree_s, &rrc->rrc_ue_head) {
+    printf("%u ", ue_context_p->ue_context.rrc_ue_id);
+    count++;
+  }
+  if (count == 0) printf("(nessuno)");
+  printf("\n");
+}
+
+// Funzione per trovare il contesto UE tramite amf_ue_ngap_id
+static rrc_gNB_ue_context_t *find_ue_context_by_amf_ue_ngap_id(gNB_RRC_INST *rrc, uint64_t amf_ue_ngap_id) {
+  rrc_gNB_ue_context_t *ue_context_p = NULL;
+  RB_FOREACH(ue_context_p, rrc_nr_ue_tree_s, &rrc->rrc_ue_head) {
+    if (ue_context_p->ue_context.amf_ue_ngap_id == amf_ue_ngap_id) {
+      // log che stampa l'id del UE
+      printf("[E2 AGENT] UE ID trovato: %lu\n", ue_context_p->ue_context.amf_ue_ngap_id);
+      return ue_context_p;
+    }
+  }
+  return NULL;
+}
