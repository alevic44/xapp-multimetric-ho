+        NR_HandoverCommand_IEs_t *ie = decoded_ho_cmd->criticalExtensions.choice.c1->choice.handoverCommand;
+        LOG_I(NR_RRC, "HO DEBUG: HandoverCommand contains handoverCommandMessage of %ld bytes", ie->handoverCommandMessage.size);
