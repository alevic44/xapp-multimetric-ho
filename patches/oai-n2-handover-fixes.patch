+/**
+ * @brief Aggiorna il RNTI del contesto UE nel CU-CP dopo l'handover
+ * @param rrc Istanza RRC
+ * @param UE Contesto UE
+ * @param new_rnti Nuovo RNTI assegnato durante l'handover
+ */
+static void update_ue_context_rnti_after_handover(gNB_RRC_INST *rrc, gNB_RRC_UE_t *UE, rnti_t new_rnti)
+{
+  if (rrc == NULL || UE == NULL) {
+    LOG_E(NR_RRC, "Invalid parameters for RNTI update after handover");
+    return;
+  }
+
+  rnti_t old_rnti = UE->rnti;
+  
+  // Aggiorna il RNTI nel contesto UE
+  UE->rnti = new_rnti;
+  
+  LOG_I(NR_RRC, "=== [HO RNTI UPDATE] Updated UE %d RNTI from %04x to %04x after handover ===", 
+        UE->rrc_ue_id, old_rnti, new_rnti);
+  
+  // Verifica che l'aggiornamento sia stato applicato correttamente
+  rrc_gNB_ue_context_t *ue_context = rrc_gNB_get_ue_context(rrc, UE->rrc_ue_id);
+  if (ue_context != NULL && ue_context->ue_context.rnti == new_rnti) {
+    LOG_I(NR_RRC, "=== [HO RNTI UPDATE] RNTI update verified successfully ===");
+  } else {
+    LOG_E(NR_RRC, "=== [HO RNTI UPDATE] RNTI update verification failed ===");
+  }
