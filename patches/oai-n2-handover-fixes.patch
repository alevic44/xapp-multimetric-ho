+      // Verifica che contenga RRCReconfiguration
+      if (decoded_ho_cmd->criticalExtensions.present == NR_HandoverCommand__criticalExtensions_PR_c1 &&
+          decoded_ho_cmd->criticalExtensions.choice.c1->present == NR_HandoverCommand__criticalExtensions__c1_PR_handoverCommand) {
