+                    if (decoded_cellgroup->spCellConfig != NULL) {
+                      LOG_I(NR_RRC, "[HO_UPER_DEBUG] spCellConfig is present in masterCellGroup\n");
+
+                      if (decoded_cellgroup->spCellConfig->reconfigurationWithSync != NULL) {
+                        NR_ReconfigurationWithSync_t *decoded_reconf_sync = decoded_cellgroup->spCellConfig->reconfigurationWithSync;
+                        LOG_I(NR_RRC, "[HO_UPER_DEBUG] ✅ reconfigurationWithSync is PRESENT in serialized RRCReconfiguration!\n");
+                        LOG_I(NR_RRC, "[HO_UPER_DEBUG]   newUE_Identity: 0x%04lx\n", (long)decoded_reconf_sync->newUE_Identity);
+                        LOG_I(NR_RRC, "[HO_UPER_DEBUG]   t304: %ld\n", (long)decoded_reconf_sync->t304);
+                        if (decoded_reconf_sync->spCellConfigCommon != NULL) {
+                          LOG_I(NR_RRC, "[HO_UPER_DEBUG]   spCellConfigCommon: PRESENT ✅\n");
+                        } else {
+                          LOG_E(NR_RRC, "[HO_UPER_DEBUG]   spCellConfigCommon: NULL ❌\n");
+                        }
+                        if (decoded_reconf_sync->rach_ConfigDedicated != NULL) {
+                          LOG_I(NR_RRC, "[HO_UPER_DEBUG]   rach_ConfigDedicated: PRESENT ✅\n");
+                        } else {
+                          LOG_E(NR_RRC, "[HO_UPER_DEBUG]   rach_ConfigDedicated: NULL ❌\n");
+                        }
+                      } else {
+                        LOG_E(NR_RRC, "[HO_UPER_DEBUG] ❌ reconfigurationWithSync is NULL in serialized RRCReconfiguration!\n");
+                      }
+                    } else {
+                      LOG_E(NR_RRC, "[HO_UPER_DEBUG] spCellConfig is NULL in masterCellGroup\n");
+                    }
+                    ASN_STRUCT_FREE(asn_DEF_NR_CellGroupConfig, decoded_cellgroup);
+                  } else {
+                    LOG_E(NR_RRC, "[HO_UPER_DEBUG] Failed to decode masterCellGroup from OCTET STRING\n");
+                  }
+                } else {
+                  LOG_E(NR_RRC, "[HO_UPER_DEBUG] masterCellGroup is NULL in nonCriticalExtension\n");
+                }
+              } else {
+                LOG_E(NR_RRC, "[HO_UPER_DEBUG] nonCriticalExtension is NULL in RRCReconfiguration\n");
+              }
+            } else {
+              LOG_W(NR_RRC, "HO DEBUG: RRCReconfiguration criticalExtensions not present or invalid!");
+            }
+
+            // Log XER della RRCReconfiguration
+            char xer_buf[4096];
+            FILE *xer_file = fmemopen(xer_buf, sizeof(xer_buf)-1, "w");
