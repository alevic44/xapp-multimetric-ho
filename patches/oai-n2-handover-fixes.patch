+    // Decodifica l'HandoverCommand completo
+    NR_HandoverCommand_t *decoded_ho_cmd = NULL;
+    asn_dec_rval_t dec_rval = uper_decode_complete(NULL, &asn_DEF_NR_HandoverCommand, (void **)&decoded_ho_cmd, ho_cmd.buf, ho_cmd.len);
