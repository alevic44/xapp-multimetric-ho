+              // Check for masterCellGroup in nonCriticalExtension
+              NR_RRCReconfiguration_IEs_t *rrc_ies = decoded_rrc->criticalExtensions.choice.rrcReconfiguration;
+              if (rrc_ies->nonCriticalExtension != NULL) {
+                LOG_I(NR_RRC, "[HO_UPER_DEBUG] RRCReconfiguration nonCriticalExtension is present\n");
+                if (rrc_ies->nonCriticalExtension->masterCellGroup != NULL) {
+                  LOG_I(NR_RRC, "[HO_UPER_DEBUG] masterCellGroup is present in nonCriticalExtension\n");
+
+                  // Decode the masterCellGroup OCTET STRING
+                  NR_CellGroupConfig_t *decoded_cellgroup = NULL;
+                  asn_dec_rval_t cellgroup_dec = uper_decode_complete(NULL, &asn_DEF_NR_CellGroupConfig,
