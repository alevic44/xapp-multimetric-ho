+                if (reconf_sync->spCellConfigCommon->physCellId != NULL) {
+                  LOG_I(NR_RRC, "[HO_UPER_DEBUG]   physCellId: %ld\n", *reconf_sync->spCellConfigCommon->physCellId);
+                } else {
+                  LOG_W(NR_RRC, "[HO_UPER_DEBUG]   physCellId: NULL\n");
+                }
+              } else {
+                LOG_E(NR_RRC, "[HO_UPER_DEBUG] spCellConfigCommon: NULL ❌ CRITICAL!\n");
+              }
+
+              if (reconf_sync->rach_ConfigDedicated != NULL) {
+                LOG_I(NR_RRC, "[HO_UPER_DEBUG] rach_ConfigDedicated: PRESENT ✅\n");
+                LOG_I(NR_RRC, "[HO_UPER_DEBUG]   present type: %d (1=uplink)\n", reconf_sync->rach_ConfigDedicated->present);
+              } else {
+                LOG_E(NR_RRC, "[HO_UPER_DEBUG] rach_ConfigDedicated: NULL ❌ CRITICAL!\n");
+              }
+
+              LOG_I(NR_RRC, "[HO_UPER_DEBUG] ========== END FIELD-BY-FIELD VERIFICATION ==========\n");
+            } else {
