+// DEBUG: Funzione per gestire il timeout delle transazioni RRC
+static void rrc_gNB_check_transaction_timeouts(gNB_RRC_INST *rrc, gNB_RRC_UE_t *UE)
+{
+  const time_t current_time = time(NULL);
+  const time_t timeout_duration = 10; // 10 secondi di timeout - sufficiente per HO e reconfigurations
+
+  for (int i = 0; i < NR_RRC_TRANSACTION_IDENTIFIER_NUMBER; ++i) {
+    // FIX: Check that transaction_start_time is actually set (non-zero)
+    // This prevents race conditions from stale/uninitialized timestamps
+    if (UE->xids[i] != RRC_ACTION_NONE && UE->transaction_start_time[i] > 0) {
+      time_t transaction_age = current_time - UE->transaction_start_time[i];
+      if (transaction_age > timeout_duration) {
+        LOG_W(RRC, "DEBUG: UE %d: Transaction %d (action %d) timed out after %ld seconds, cleaning up\n",
+              UE->rrc_ue_id, i, UE->xids[i], transaction_age);
+        UE->xids[i] = RRC_ACTION_NONE;
+        UE->transaction_start_time[i] = 0;
+      }
+    }
+  }
+}
