+        asn_dec_rval_t dl_dcch_dec_rval = uper_decode_complete(NULL, &asn_DEF_NR_DL_DCCH_Message, (void **)&dl_dcch_msg, ie->handoverCommandMessage.buf, ie->handoverCommandMessage.size);
