+/* Temporary lookup table functions for N2 Handover support */
+
+/* Get current time in milliseconds */
+static uint64_t get_current_time_ms(void)
+{
+  struct timespec ts;
+  clock_gettime(CLOCK_MONOTONIC, &ts);
+  return (uint64_t)ts.tv_sec * 1000 + ts.tv_nsec / 1000000;
+}
+
+/* Find entry in temporary N2 HO lookup table (with timeout cleanup) */
+static rrc_gNB_ue_context_t *nr_ho_temp_lookup_find(gNB_RRC_INST *rrc,
+                                                      long source_pci,
+                                                      rnti_t source_rnti)
+{
+  if (!rrc)
+    return NULL;
+
+  uint64_t current_time_ms = get_current_time_ms();
+  rrc_gNB_ue_context_t *result = NULL;
+
+  /* Clean up expired entries and search for match */
+  int write_idx = 0;
+  for (int read_idx = 0; read_idx < rrc->ho_temp_lookup_count; read_idx++) {
+    nr_ho_temp_lookup_t *entry = &rrc->ho_temp_lookup[read_idx];
+    uint64_t age_ms = current_time_ms - entry->timestamp_ms;
+
+    if (age_ms > TEMP_HO_LOOKUP_TIMEOUT_MS) {
+      LOG_W(NR_RRC, "[HO_TEMP] Removing expired N2 HO lookup: PCI=%ld, RNTI=0x%04x (age=%lu ms)\n",
+            entry->source_pci, entry->source_rnti, age_ms);
+      continue; /* Skip this entry (remove) */
+    }
+
+    /* Keep this entry */
+    if (read_idx != write_idx)
+      rrc->ho_temp_lookup[write_idx] = rrc->ho_temp_lookup[read_idx];
+
+    /* Check if this is our target */
+    if (entry->source_pci == source_pci && entry->source_rnti == source_rnti) {
+      result = entry->ue_context;
+      LOG_W(NR_RRC, "[HO_TEMP] Found N2 HO lookup match: PCI=%ld, RNTI=0x%04x -> UE rrc_ue_id=%d (age=%lu ms)\n",
+            source_pci, source_rnti, result->ue_context.rrc_ue_id, age_ms);
+    }
+
+    write_idx++;
+  }
+
+  rrc->ho_temp_lookup_count = write_idx;
+  return result;
+}
