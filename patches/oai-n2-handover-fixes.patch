+      uint8_t cellgroup_buf[8192];
+      asn_enc_rval_t cellgroup_enc = uper_encode_to_buffer(&asn_DEF_NR_CellGroupConfig, NULL, params.cell_group_config, cellgroup_buf, sizeof(cellgroup_buf));
+      if (cellgroup_enc.encoded > 0) {
+        int cellgroup_bytes = (cellgroup_enc.encoded + 7) / 8;
+        LOG_I(NR_RRC, "[HO_UPER_DEBUG] masterCellGroup UPER encoded: %ld bits (%d bytes)\n",
+              cellgroup_enc.encoded, cellgroup_bytes);
+
+        // Dump masterCellGroup hex payload
+        LOG_I(NR_RRC, "[HO_UPER_DEBUG] ========== masterCellGroup HEX DUMP ==========\n");
+        for (int i = 0; i < cellgroup_bytes; i++) {
+          if (i % 16 == 0) {
+            LOG_I(NR_RRC, "[HO_UPER_DEBUG] [%04d] ", i);
+          }
+          LOG_I(NR_RRC, "%02X ", cellgroup_buf[i]);
+          if ((i + 1) % 16 == 0) {
+            LOG_I(NR_RRC, "\n");
+          }
+        }
+        if (cellgroup_bytes % 16 != 0) {
+          LOG_I(NR_RRC, "\n");
+        }
+        LOG_I(NR_RRC, "[HO_UPER_DEBUG] ========== END masterCellGroup HEX DUMP ==========\n");
+      } else {
+        LOG_E(NR_RRC, "[HO_UPER_DEBUG] Failed to encode masterCellGroup\n");
+      }
+    } else {
+      LOG_E(NR_RRC, "[HO_UPER_DEBUG] masterCellGroup.spCellConfig.reconfigurationWithSync: NULL ❌ NOT ADDED!\n");
+    }
