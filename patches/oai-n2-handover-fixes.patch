+    if (reconf_sync_check != NULL) {
+      LOG_I(NR_RRC, "[HO_UPER_DEBUG] masterCellGroup.spCellConfig.reconfigurationWithSync: PRESENT\n");
+      LOG_I(NR_RRC, "[HO_UPER_DEBUG]   newUE_Identity: 0x%04lx\n", (long)reconf_sync_check->newUE_Identity);
+      LOG_I(NR_RRC, "[HO_UPER_DEBUG]   t304: %ld\n", (long)reconf_sync_check->t304);
+      if (reconf_sync_check->spCellConfigCommon != NULL) {
+        LOG_I(NR_RRC, "[HO_UPER_DEBUG]   spCellConfigCommon: PRESENT\n");
+      } else {
+        LOG_E(NR_RRC, "[HO_UPER_DEBUG]   spCellConfigCommon: NULL ❌ CRITICAL!\n");
+      }
+      if (reconf_sync_check->rach_ConfigDedicated != NULL) {
+        LOG_I(NR_RRC, "[HO_UPER_DEBUG]   rach_ConfigDedicated: PRESENT\n");
+      } else {
+        LOG_E(NR_RRC, "[HO_UPER_DEBUG]   rach_ConfigDedicated: NULL ❌ CRITICAL!\n");
+      }
