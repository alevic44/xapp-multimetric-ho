+  LOG_I(NR_RRC, "HO DEBUG: rrc_gNB_encode_HandoverCommand: NH=%s, NCC=%d, ciphering=%ld, integrity=%ld, keyToUse=%s",
+        nh_hex, UE->nh_ncc, (long)UE->ciphering_algorithm, (long)UE->integrity_algorithm, key_type);
