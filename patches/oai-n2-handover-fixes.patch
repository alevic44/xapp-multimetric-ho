+/** @brief This callback is used by the target gNB
+ *         to trigger the Handover Request Acknowledge towards the AMF */
+static void nr_rrc_n2_ho_acknowledge(gNB_RRC_INST *rrc, gNB_RRC_UE_t *UE)
+{
+  LOG_I(NR_RRC, "TRACE HO: [IN] nr_rrc_n2_ho_acknowledge per UE %d", UE->rrc_ue_id);
+  if (rrc == NULL || UE == NULL) { LOG_W(NR_RRC, "TRACE HO: [RETURN] nr_rrc_n2_ho_acknowledge: rrc or UE null"); return; }
+  if (!cu_exists_f1_ue_data(UE->rrc_ue_id)) {
+    LOG_E(NR_RRC, "No CU found for rrc_ue_id %d\n", UE->rrc_ue_id);
+    ngap_handover_failure_t fail = {.amf_ue_ngap_id = UE->amf_ue_ngap_id,
+                                    .cause.type = NGAP_CAUSE_RADIO_NETWORK,
+                                    .cause.value = NGAP_CAUSE_RADIO_NETWORK_RELEASE_DUE_TO_NGRAN_GENERATED_REASON};
+    UE->ho_context->target->ho_failure(rrc, UE->rrc_ue_id, &fail);
+    LOG_W(NR_RRC, "TRACE HO: [RETURN] nr_rrc_n2_ho_acknowledge: cu_exists_f1_ue_data(UE->rrc_ue_id) == false");
+    return;
+  }
+
+  f1_ue_data_t previous_data = cu_get_f1_ue_data(UE->rrc_ue_id);
+  previous_data.secondary_ue = UE->ho_context->target->du_ue_id;
+  if (!cu_update_f1_ue_data(UE->rrc_ue_id, &previous_data)) {
+    LOG_E(NR_RRC, "Failed to update F1 UE data for UE %d\n", UE->rrc_ue_id);
+    ngap_handover_failure_t fail = {.amf_ue_ngap_id = UE->amf_ue_ngap_id,
+                                    .cause.type = NGAP_CAUSE_RADIO_NETWORK,
+                                    .cause.value = NGAP_CAUSE_RADIO_NETWORK_RELEASE_DUE_TO_NGRAN_GENERATED_REASON};
+    UE->ho_context->target->ho_failure(rrc, UE->rrc_ue_id, &fail);
+    LOG_W(NR_RRC, "TRACE HO: [RETURN] nr_rrc_n2_ho_acknowledge: cu_update_f1_ue_data(UE->rrc_ue_id, &previous_data) == false");
+    return;
+  }
+
+  LOG_I(NR_RRC, "Updated CU F1AP Context for UE %d, DU Id : %u\n", UE->rrc_ue_id, UE->ho_context->target->du_ue_id);
+
+  uint8_t xid = rrc_gNB_get_next_transaction_identifier(rrc->module_id);
+  UE->xids[xid] = RRC_DEDICATED_RECONF;
+  byte_array_t hoCommand = rrc_gNB_encode_HandoverCommand(UE, rrc, xid);
+  if (hoCommand.len < 0) {
+    LOG_E(NR_RRC, "ASN1 message encoding failed: failed to generate Handover Command Message\n");
+    ngap_handover_failure_t fail = {.amf_ue_ngap_id = UE->amf_ue_ngap_id,
+                                    .cause.type = NGAP_CAUSE_RADIO_NETWORK,
+                                    .cause.value = NGAP_CAUSE_RADIO_NETWORK_HO_FAILURE_IN_TARGET_5GC_NGRAN_NODE_OR_TARGET_SYSTEM};
+    UE->ho_context->target->ho_failure(rrc, UE->rrc_ue_id, &fail);
+    LOG_W(NR_RRC, "TRACE HO: [RETURN] nr_rrc_n2_ho_acknowledge: hoCommand.len < 0");
+    return;
+  } else {
+    LOG_D(NR_RRC, "HO LOG: Handover Command for UE %u Encoded (%ld bytes)\n", UE->rrc_ue_id, hoCommand.len);
+  }
+
+  rrc_gNB_send_NGAP_HANDOVER_REQUEST_ACKNOWLEDGE(rrc, UE, hoCommand);
+  LOG_I(NR_RRC, "TRACE HO: [OUT] nr_rrc_n2_ho_acknowledge per UE %d", UE->rrc_ue_id);
+}
